        },
        "version": "1.0"
    },
    "host": "localhost:5200",
    "basePath": "/",
    "paths": {
        "/ai/ai-classification": {
            "post": {
                "description": "根据支付宝账单数据，调用AI自动匹配支出/收入分类",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "AI"
                ],
                "summary": "AI智能分类账单",
                "parameters": [
                    {
                        "description": "账单数据",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/service.PostAiClassificationRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "分类结果",
                        "schema": {
                            "$ref": "#/definitions/model.Response-service_PostAiClassificationResult"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-any"
                        }
                    },
                    "500": {
                        "description": "服务器错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-any"
                        }
                    }
                }
            }
        },
        "/classification": {
            "get": {
                "description": "获取所有支出分类，按树形结构返回",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "支出分类"
                ],
                "summary": "获取支出分类树",
                "responses": {
                    "200": {
                        "description": "成功返回分类树",
                        "schema": {
                            "$ref": "#/definitions/model.Response-array_service_TreeNodeDTO"
                        }
                    },
                    "500": {
                        "description": "服务器错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-any"
                        }
                    }
                }
            },
            "put": {
                "description": "替换数据库中的所有支出分类数据，前端传入完整的树结构",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "支出分类"
                ],
                "summary": "更新整个支出分类树",
                "parameters": [
                    {
                        "description": "分类树数据",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/service.UpdateTreeRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "更新成功",
                        "schema": {
                            "$ref": "#/definitions/model.Response-bool"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-any"
                        }
                    },
                    "500": {
                        "description": "服务器错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-any"
                        }
                    }
                }
            }
        },
        "/export": {
            "post": {
                "description": "接收 JSON 数组，生成并以附件形式下载 Excel 文件",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/octet-stream"
                ],
                "tags": [
                    "导出"
                ],
                "summary": "导出 Excel",
                "parameters": [
                    {
                        "description": "导出数据列表",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/handler.ExportItem"
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Excel 文件（.xlsx）",
                        "schema": {
                            "type": "file"
                        }
                    },
                    "400": {
                        "description": "参数错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-bool"
                        }
                    },
                    "500": {
                        "description": "服务器错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-bool"
                        }
                    }
                }
            }
        },
        "/income-classification": {
            "get": {
                "description": "获取所有收入分类，按树形结构返回",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "收入分类"
                ],
                "summary": "获取收入分类树",
                "responses": {
                    "200": {
                        "description": "成功返回分类树",
                        "schema": {
                            "$ref": "#/definitions/model.Response-array_service_TreeNodeDTO"
                        }
                    },
                    "500": {
                        "description": "服务器错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-any"
                        }
                    }
                }
            },
            "put": {
                "description": "替换数据库中的所有收入分类数据，前端传入完整的树结构",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "收入分类"
                ],
                "summary": "更新整个收入分类树",
                "parameters": [
                    {
                        "description": "分类树数据",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/service.UpdateTreeRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "更新成功",
                        "schema": {
                            "$ref": "#/definitions/model.Response-bool"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-any"
                        }
                    },
                    "500": {
                        "description": "服务器错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-any"
                        }
                    }
                }
            }
        },
        "/upload": {
            "post": {
                "description": "上传 GB2312/GBK 编码的 CSV 文件，自动转码后解析并返回数据行列表",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "上传"
                ],
                "summary": "上传 CSV 文件（GB2312 编码）",
                "parameters": [
                    {
                        "type": "file",
                        "description": "CSV 文件（GB2312 编码）",
                        "name": "file",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "解析后的数据行列表",
                        "schema": {
                            "$ref": "#/definitions/model.Response-array_array_string"
                        }
                    },
                    "400": {
                        "description": "文件获取或解析失败",
                        "schema": {
                            "$ref": "#/definitions/model.Response-bool"
                        }
                    },
                    "500": {
                        "description": "服务器错误",
                        "schema": {
                            "$ref": "#/definitions/model.Response-bool"
                        }
                    }
                }
            }
        }
    },
